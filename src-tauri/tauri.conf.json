{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "elevenscribe",
  "version": "0.4.0",
  "identifier": "com.pentoai.elevenscribe",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "elevenscribe",
        "width": 800,
        "height": 600,
        "visible": false
      },
      {
        "label": "overlay",
        "title": "",
        "width": 480,
        "height": 180,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "focus": false,
        "url": "overlay.html"
      },
      {
        "label": "readaloud",
        "title": "",
        "width": 480,
        "height": 160,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "focus": false,
        "url": "readaloud.html"
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
